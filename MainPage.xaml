<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Examen2DesarrolloMovil.MainPage"
             BackgroundColor="#4f3f9b">
    
    <Grid RowDefinitions="0.3*, 0.7*">

        <Grid Grid.Row="0" ColumnDefinitions="*, *">
            <VerticalStackLayout Grid.Column="0" VerticalOptions="Center" HorizontalOptions="Center">
                <Label Text="MAUI" FontSize="32" FontAttributes="Bold" TextColor="White" HorizontalOptions="Center"/>
                <Label Text="DELIVERY CO." FontSize="12" TextColor="White" HorizontalOptions="Center"/>
            </VerticalStackLayout>

            <!-- Removed skia:SKLottieView due to missing assembly reference -->
            <!-- You can add a placeholder or image here if needed -->
            <BoxView Grid.Column="1" HeightRequest="100" WidthRequest="100" Color="Transparent" VerticalOptions="Center"/>
        </Grid>

        <Grid Grid.Row="1">
            <RoundRectangle Fill="White" CornerRadius="30,30,0,0" Margin="0,-30,0,0"/>

            <VerticalStackLayout Padding="30" Spacing="15">
                <Label Text="Welcome!" FontSize="28" FontAttributes="Bold" TextColor="#2D2D2D"/>
                <Label Text="Log in to continue" FontSize="16" TextColor="Gray" Margin="0,0,0,10"/>

                <Grid ColumnDefinitions="60, *">
                    <RoundRectangle Grid.Column="0" Fill="#EDEBF6" CornerRadius="10" HeightRequest="50" WidthRequest="50"/>
                    <Entry Grid.Column="1" Placeholder="EMAIL" VerticalOptions="Center" Keyboard="Email"/>
                </Grid>

                <Grid ColumnDefinitions="60, *">
                    <RoundRectangle Grid.Column="0" Fill="#EDEBF6" CornerRadius="10" HeightRequest="50" WidthRequest="50"/>
                    <Entry Grid.Column="1" Placeholder="PASSWORD" IsPassword="True" VerticalOptions="Center"/>
                </Grid>

                <Button Text="Login" BackgroundColor="#4f3f9b" TextColor="White" HeightRequest="55" CornerRadius="10" Margin="0,20,0,0"/>

                <Label Text="Forgot your password?" TextColor="Blue" TextDecorations="Underline" HorizontalOptions="Center" Margin="0,10"/>

                <Button Text="Create your Account" BackgroundColor="Transparent" TextColor="#4f3f9b" BorderColor="#4f3f9b" BorderWidth="1" HeightRequest="55" CornerRadius="10"/>
            </VerticalStackLayout>
        </Grid>
    </Grid>
</ContentPage>
